#!/bin/bash
# Costa OS Installer — runs from the live ISO
# Installs Arch Linux with Costa OS configs and AI layer
#
# Usage:
#   costa-install              Interactive CLI mode
#   costa-install --gui FILE   GUI mode: reads config from JSON, outputs structured progress

set -o pipefail

# ─── GUI mode ─────────────────────────────────────────────────
GUI_MODE=false
GUI_CONFIG=""

if [ "$1" = "--gui" ] && [ -n "$2" ]; then
    GUI_MODE=true
    GUI_CONFIG="$2"
    # In GUI mode, output structured lines for the frontend
    exec > >(tee /tmp/costa-install.log) 2>&1
else
    exec > >(tee /tmp/costa-install.log) 2>&1
fi

CYAN='\033[36m'
WARM='\033[38;2;194;120;73m'
GREEN='\033[32m'
RED='\033[31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

banner() {
    [ "$GUI_MODE" = true ] && return
    echo -e "${CYAN}"
    echo '   ╔═══════════════════════════════════════╗'
    echo '   ║         Costa OS Installer            ║'
    echo '   ║     AI-Native Linux Distribution      ║'
    echo '   ╚═══════════════════════════════════════╝'
    echo -e "${RESET}"
}

prompt() {
    echo -ne "${WARM}$1${RESET} "
    read -r REPLY
}

info() {
    if [ "$GUI_MODE" = true ]; then
        echo "LOG:$1"
    else
        echo -e "${GREEN}→${RESET} $1"
    fi
}
warn() {
    if [ "$GUI_MODE" = true ]; then
        echo "LOG:WARNING: $1"
    else
        echo -e "${RED}!${RESET} $1"
    fi
}

gui_step() {
    # Output structured step for GUI frontend
    # Usage: gui_step name percentage "message"
    if [ "$GUI_MODE" = true ]; then
        echo "STEP:$1:$2:$3"
    fi
}

gui_error() {
    if [ "$GUI_MODE" = true ]; then
        echo "ERROR:$1"
    fi
}

# ─── Pre-flight checks ──────────────────────────────────────
banner

if [ "$(id -u)" -ne 0 ]; then
    warn "Must run as root. Try: sudo costa-install"
    gui_error "Must run as root"
    exit 1
fi

# Check EFI
if [ ! -d /sys/firmware/efi ]; then
    warn "EFI not detected. Costa OS requires UEFI boot."
    gui_error "EFI not detected. Costa OS requires UEFI boot."
    exit 1
fi

# ─── Network setup ────────────────────────────────────────
check_internet() {
    ping -c1 -W2 archlinux.org &>/dev/null
}

wifi_connect() {
    # Enable wifi
    nmcli radio wifi on 2>/dev/null
    sleep 2

    # Check wifi hardware
    if ! nmcli radio wifi 2>/dev/null | grep -q "enabled"; then
        warn "No WiFi adapter found. Plug in ethernet and press Enter."
        read -r
        return
    fi

    nmcli device wifi rescan 2>/dev/null
    sleep 3

    while true; do
        echo ""
        info "Available WiFi networks:"
        echo ""

        # Parse columnar output with awk — handles SSIDs with colons, parens, etc.
        NETWORKS=$(nmcli -f SSID,SIGNAL,SECURITY device wifi list --rescan no 2>/dev/null | tail -n +2 | awk '{
            for (i = NF; i >= 1; i--) {
                if ($i ~ /^[0-9]+$/) {
                    ssid = ""; for (j = 1; j < i; j++) ssid = ssid (j>1?" ":"") $j
                    sig = $i
                    sec = ""; for (j = i+1; j <= NF; j++) sec = sec (j>i+1?" ":"") $j
                    if (ssid != "" && ssid != "--") printf "%s\t%s\t%s\n", ssid, sig, sec
                    break
                }
            }
        }')
        if [ -z "$NETWORKS" ]; then
            warn "No networks found."
            prompt "Rescan? (Y/n):"
            [ "$REPLY" = "n" ] && return
            nmcli device wifi rescan 2>/dev/null
            sleep 3
            continue
        fi

        declare -A SEEN_SSIDS
        SSID_LIST=()
        SEC_LIST=()
        NUM=0

        while IFS=$'\t' read -r ssid signal security; do
            [ -z "$ssid" ] && continue
            [ -n "${SEEN_SSIDS[$ssid]+x}" ] && continue
            SEEN_SSIDS[$ssid]=1
            NUM=$((NUM + 1))
            SSID_LIST+=("$ssid")
            SEC_LIST+=("$security")

            signal=${signal:-0}
            [[ "$signal" =~ ^[0-9]+$ ]] || signal=0
            bars=$((signal / 20))
            bar_str=""
            for ((i=0; i<bars; i++)); do bar_str+="█"; done
            for ((i=bars; i<5; i++)); do bar_str+="░"; done

            lock="  "
            [ -n "$security" ] && [ "$security" != "--" ] && [ "$security" != "" ] && lock="🔒"

            printf "    %2d. %s %-32s %s %3s%%  %s\n" "$NUM" "$lock" "$ssid" "$bar_str" "$signal" "$security"
            [ "$NUM" -ge 20 ] && break
        done <<< "$NETWORKS"

        echo ""
        echo -e "     ${DIM}r = rescan${RESET}"
        echo ""
        prompt "Network number:"

        case "$REPLY" in
            r|R)
                unset SEEN_SSIDS
                nmcli device wifi rescan 2>/dev/null
                sleep 3
                continue
                ;;
        esac

        if ! [[ "$REPLY" =~ ^[0-9]+$ ]] || [ "$REPLY" -lt 1 ] || [ "$REPLY" -gt "$NUM" ]; then
            warn "Invalid choice"
            unset SEEN_SSIDS
            continue
        fi

        idx=$(($REPLY - 1))
        ssid="${SSID_LIST[$idx]}"
        security="${SEC_LIST[$idx]}"

        # Try saved connection
        if nmcli connection up "$ssid" 2>/dev/null; then
            sleep 2
            if check_internet; then
                info "Connected to $ssid"
                return
            fi
        fi

        # Need password
        if [ -n "$security" ] && [ "$security" != "--" ] && [ "$security" != "Open" ]; then
            echo -ne "${WARM}Password for $ssid: ${RESET}"
            read -r password
            [ -z "$password" ] && { unset SEEN_SSIDS; continue; }

            RESULT=$(nmcli device wifi connect "$ssid" password "$password" 2>&1)
            if [ $? -eq 0 ]; then
                sleep 2
                for attempt in 1 2 3 4 5; do
                    if check_internet; then
                        info "Connected to $ssid"
                        return
                    fi
                    sleep 2
                done
                info "Connected to $ssid (internet may take a moment)"
                return
            else
                warn "Connection failed:"
                echo -e "  ${DIM}$RESULT${RESET}"
                echo ""
                prompt "Try again? (Y/n):"
                [ "$REPLY" = "n" ] && { unset SEEN_SSIDS; return; }
                unset SEEN_SSIDS
                continue
            fi
        else
            if nmcli device wifi connect "$ssid" 2>&1; then
                sleep 2
                info "Connected to $ssid"
                return
            fi
            warn "Connection failed"
            unset SEEN_SSIDS
            continue
        fi
    done
}

# ─── GUI mode: read config from JSON ─────────────────────────
if [ "$GUI_MODE" = true ]; then
    if [ ! -f "$GUI_CONFIG" ]; then
        gui_error "Config file not found: $GUI_CONFIG"
        exit 1
    fi
    DISK=$(jq -r '.disk' "$GUI_CONFIG")
    PARTITION_MODE=$(jq -r '.partition_mode' "$GUI_CONFIG")
    ALONGSIDE_SHRINK_TO_MB=$(jq -r '.alongside_shrink_to_mb // 0' "$GUI_CONFIG")
    ALONGSIDE_PARTITION=$(jq -r '.alongside_partition // ""' "$GUI_CONFIG")
    MANUAL_ROOT_PARTITION=$(jq -r '.manual_root_partition // ""' "$GUI_CONFIG")
    MANUAL_EFI_PARTITION=$(jq -r '.manual_efi_partition // ""' "$GUI_CONFIG")
    USERNAME=$(jq -r '.username' "$GUI_CONFIG")
    HOSTNAME=$(jq -r '.hostname // "costa"' "$GUI_CONFIG")
    PASSWORD1=$(jq -r '.password' "$GUI_CONFIG")
    TIMEZONE=$(jq -r '.timezone // "UTC"' "$GUI_CONFIG")

    if [ ! -b "$DISK" ]; then
        gui_error "Disk $DISK not found"
        exit 1
    fi

    gui_step preflight 1 "Pre-flight checks passed"
else
    # ─── Interactive CLI mode ─────────────────────────────────

    # Check internet — if not available, run WiFi setup inline
    info "Checking internet connectivity..."
    INTERNET_OK=false
    for i in $(seq 1 5); do
        if check_internet; then
            INTERNET_OK=true
            break
        fi
        sleep 2
    done

    while [ "$INTERNET_OK" != "true" ]; do
        warn "No internet connection."
        echo ""
        echo -e "  ${BOLD}1${RESET}. Connect to WiFi"
        echo -e "  ${BOLD}2${RESET}. Retry (if ethernet just plugged in)"
        echo -e "  ${BOLD}3${RESET}. Open nmtui (advanced)"
        echo ""
        prompt "Choice [1]:"
        case "${REPLY:-1}" in
            1) wifi_connect ;;
            2) ;;
            3) nmtui; sleep 2 ;;
        esac
        if check_internet; then
            INTERNET_OK=true
        fi
    done

    # ─── Disk selection ──────────────────────────────────────────
    info "Available disks:"
    lsblk -d -o NAME,SIZE,TYPE,MODEL | grep disk
    echo ""
    prompt "Install disk (e.g., sda, nvme0n1):"
    DISK="/dev/$REPLY"

    if [ ! -b "$DISK" ]; then
        warn "Disk $DISK not found"
        exit 1
    fi

    echo ""
    warn "This will ERASE ALL DATA on $DISK"
    prompt "Type 'yes' to continue:"
    [ "$REPLY" != "yes" ] && exit 1

    PARTITION_MODE="erase_all"

    # ─── User setup ──────────────────────────────────────────────
    echo ""
    while true; do
        prompt "Username:"
        USERNAME="$REPLY"
        if [[ "$USERNAME" =~ ^[a-z][a-z0-9_-]*$ ]] && [ ${#USERNAME} -ge 1 ]; then
            break
        fi
        warn "Invalid username. Use lowercase letters, numbers, hyphens, underscores."
    done

    prompt "Hostname [costa]:"
    HOSTNAME="${REPLY:-costa}"

    # ─── Password ────────────────────────────────────────────────
    while true; do
        echo ""
        echo -ne "${WARM}Password for $USERNAME: ${RESET}"
        read -rs PASSWORD1
        echo ""
        echo -ne "${WARM}Confirm password: ${RESET}"
        read -rs PASSWORD2
        echo ""
        if [ "$PASSWORD1" = "$PASSWORD2" ] && [ -n "$PASSWORD1" ]; then
            break
        else
            warn "Passwords do not match or are empty. Try again."
        fi
    done

    # ─── Summary ─────────────────────────────────────────────────
    echo ""
    echo -e "${CYAN}╭─────────────────────────────────────╮${RESET}"
    echo -e "${CYAN}│${RESET}  ${BOLD}Install Summary${RESET}                    ${CYAN}│${RESET}"
    echo -e "${CYAN}├─────────────────────────────────────┤${RESET}"
    printf "${CYAN}│${RESET}  %-10s %-24s${CYAN}│${RESET}\n" "Disk:" "$DISK"
    printf "${CYAN}│${RESET}  %-10s %-24s${CYAN}│${RESET}\n" "User:" "$USERNAME"
    printf "${CYAN}│${RESET}  %-10s %-24s${CYAN}│${RESET}\n" "Host:" "$HOSTNAME"
    echo -e "${CYAN}╰─────────────────────────────────────╯${RESET}"
    echo ""
    prompt "Begin installation? (Y/n):"
    [ "$REPLY" = "n" ] && exit 0
fi

# ═══════════════════════════════════════════════════════════════
# FULLY AUTOMATED FROM HERE — NO MORE USER INPUT
# ═══════════════════════════════════════════════════════════════

# Initialize pacman keyring if not already done
if [ ! -f /etc/pacman.d/gnupg/trustdb.gpg ]; then
    gui_step keyring 2 "Initializing package signing keys..."
    info "Initializing package signing keys..."
    pacman-key --init
    pacman-key --populate
fi

# ─── Partitioning ────────────────────────────────────────────
gui_step partition 3 "Partitioning disk..."
info "Partitioning $DISK..."

# Detect if NVMe (uses p1, p2) or SATA (uses 1, 2)
if [[ "$DISK" == *nvme* ]]; then
    PART_PREFIX="${DISK}p"
else
    PART_PREFIX="${DISK}"
fi

case "${PARTITION_MODE:-erase_all}" in
    erase_all)
        parted -s "$DISK" mklabel gpt || { warn "Partitioning failed"; gui_error "Partitioning failed"; exit 1; }
        parted -s "$DISK" mkpart ESP fat32 1MiB 513MiB
        parted -s "$DISK" set 1 esp on
        parted -s "$DISK" mkpart root ext4 513MiB 100%

        EFI_PART="${PART_PREFIX}1"
        ROOT_PART="${PART_PREFIX}2"

        mkfs.fat -F32 "$EFI_PART" || { warn "Failed to format EFI partition"; gui_error "Failed to format EFI partition"; exit 1; }
        mkfs.ext4 -F "$ROOT_PART" || { warn "Failed to format root partition"; gui_error "Failed to format root partition"; exit 1; }

        mount "$ROOT_PART" /mnt || { warn "Failed to mount root partition"; gui_error "Failed to mount root"; exit 1; }
        mount --mkdir "$EFI_PART" /mnt/boot
        ;;

    alongside)
        gui_step partition 3 "Shrinking existing partition..."
        info "Shrinking $ALONGSIDE_PARTITION to ${ALONGSIDE_SHRINK_TO_MB}MB..."

        # Detect filesystem and shrink accordingly
        ALONGSIDE_FS=$(lsblk -no FSTYPE "$ALONGSIDE_PARTITION" 2>/dev/null)
        case "$ALONGSIDE_FS" in
            ntfs)
                # Unmount if mounted
                umount "$ALONGSIDE_PARTITION" 2>/dev/null || true
                # Shrink NTFS filesystem first
                ntfsresize --force --size "${ALONGSIDE_SHRINK_TO_MB}M" "$ALONGSIDE_PARTITION" || {
                    warn "NTFS resize failed"; gui_error "Failed to resize NTFS partition"; exit 1; }
                ;;
            ext4)
                umount "$ALONGSIDE_PARTITION" 2>/dev/null || true
                e2fsck -f -y "$ALONGSIDE_PARTITION" || true
                resize2fs "$ALONGSIDE_PARTITION" "${ALONGSIDE_SHRINK_TO_MB}M" || {
                    warn "ext4 resize failed"; gui_error "Failed to resize ext4 partition"; exit 1; }
                ;;
            *)
                warn "Unsupported filesystem for resize: $ALONGSIDE_FS"
                gui_error "Cannot resize $ALONGSIDE_FS filesystem"
                exit 1
                ;;
        esac

        # Shrink the partition table entry
        PART_NUM=$(echo "$ALONGSIDE_PARTITION" | grep -o '[0-9]*$')
        parted -s "$DISK" resizepart "$PART_NUM" "${ALONGSIDE_SHRINK_TO_MB}MiB" || {
            warn "Partition resize failed"; gui_error "Partition table resize failed"; exit 1; }

        gui_step partition 4 "Creating Costa OS partitions..."
        # Find where the free space starts
        FREE_START="${ALONGSIDE_SHRINK_TO_MB}MiB"

        # Check if EFI partition already exists on disk
        EXISTING_EFI=$(lsblk -no NAME,PARTTYPE "$DISK" 2>/dev/null | grep -i "c12a7328-f81f-11d2-ba4b-00a0c93ec93b" | awk '{print $1}' | head -1)
        if [ -n "$EXISTING_EFI" ]; then
            EFI_PART="/dev/$EXISTING_EFI"
            info "Reusing existing EFI partition: $EFI_PART"
            # Create only root partition in free space
            parted -s "$DISK" mkpart root ext4 "$FREE_START" 100%
            # Find the new partition
            ROOT_PART=$(lsblk -no NAME "$DISK" | tail -1)
            ROOT_PART="/dev/$ROOT_PART"
        else
            # Create EFI + root in free space
            EFI_END="$((ALONGSIDE_SHRINK_TO_MB + 512))MiB"
            parted -s "$DISK" mkpart ESP fat32 "$FREE_START" "$EFI_END"
            NEW_EFI_NUM=$(lsblk -no NAME "$DISK" | wc -l)
            parted -s "$DISK" set "$NEW_EFI_NUM" esp on
            parted -s "$DISK" mkpart root ext4 "$EFI_END" 100%
            EFI_PART="${PART_PREFIX}${NEW_EFI_NUM}"
            ROOT_PART=$(lsblk -no NAME "$DISK" | tail -1)
            ROOT_PART="/dev/$ROOT_PART"
            mkfs.fat -F32 "$EFI_PART" || { warn "Failed to format EFI"; gui_error "EFI format failed"; exit 1; }
        fi

        mkfs.ext4 -F "$ROOT_PART" || { warn "Failed to format root"; gui_error "Root format failed"; exit 1; }
        mount "$ROOT_PART" /mnt || { warn "Failed to mount root"; gui_error "Mount failed"; exit 1; }
        mount --mkdir "$EFI_PART" /mnt/boot
        ;;

    manual)
        ROOT_PART="$MANUAL_ROOT_PARTITION"
        EFI_PART="$MANUAL_EFI_PARTITION"

        mkfs.ext4 -F "$ROOT_PART" || { warn "Failed to format root"; gui_error "Root format failed"; exit 1; }
        mount "$ROOT_PART" /mnt || { warn "Failed to mount root"; gui_error "Mount failed"; exit 1; }
        mount --mkdir "$EFI_PART" /mnt/boot
        ;;

    *)
        warn "Unknown partition mode: $PARTITION_MODE"
        gui_error "Unknown partition mode: $PARTITION_MODE"
        exit 1
        ;;
esac

info "Partitioned and mounted"

# ─── Install base system ─────────────────────────────────────
gui_step pacstrap 5 "Installing base system (this takes a few minutes)..."
info "Installing base system (this takes a few minutes)..."
pacstrap -K /mnt base linux linux-firmware base-devel \
    networkmanager grub efibootmgr \
    hyprland ghostty zsh waybar dunst rofi-wayland ydotool \
    pipewire pipewire-alsa pipewire-pulse wireplumber \
    firefox thunar gvfs git git-delta lazygit zellij docker docker-compose \
    nodejs npm \
    ttf-jetbrains-mono-nerd noto-fonts noto-fonts-emoji \
    papirus-icon-theme adw-gtk-theme qt5ct qt6ct \
    xdg-desktop-portal-hyprland polkit-kde-agent \
    swaybg grim slurp wl-clipboard cliphist wtype playerctl \
    greetd greetd-tuigreet brightnessctl \
    ripgrep fd fzf bat eza zoxide jq htop fastfetch less sox uv socat \
    mesa vulkan-icd-loader v4l-utils python python-requests python-evdev python-yaml python-gobject python-pip libnotify \
    gtk4 libadwaita swww hyprpicker power-profiles-daemon \
    zsh-autosuggestions zsh-syntax-highlighting starship \
    realtime-privileges noise-suppression-for-voice inetutils || { warn "pacstrap failed — check internet connection"; gui_error "pacstrap failed — check internet connection"; exit 1; }

# ─── Generate fstab ──────────────────────────────────────────
gui_step fstab 75 "Generating filesystem table..."
genfstab -U /mnt >> /mnt/etc/fstab
info "Generated fstab"

# ─── Chroot setup ────────────────────────────────────────────
gui_step configure 77 "Configuring system..."
info "Configuring system..."

# Determine timezone
INSTALL_TZ="${TIMEZONE:-UTC}"

arch-chroot /mnt bash -c "
    # Timezone
    ln -sf '/usr/share/zoneinfo/$INSTALL_TZ' /etc/localtime
    hwclock --systohc

    # Locale
    sed -i 's/#en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen
    locale-gen
    echo 'LANG=en_US.UTF-8' > /etc/locale.conf

    # Hostname
    echo '$HOSTNAME' > /etc/hostname

    # User
    useradd -m -G wheel,realtime,docker -s /usr/bin/zsh '$USERNAME'
    echo '%wheel ALL=(ALL:ALL) ALL' > /etc/sudoers.d/wheel

    # Bootloader — set safe defaults for common GPU hardware
    sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT=\"loglevel=3 quiet i915.enable_psr=0 nvidia_drm.modeset=1 iommu=pt\"/' /etc/default/grub
    grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=Costa
    grub-mkconfig -o /boot/grub/grub.cfg

    # Enable services
    systemctl enable NetworkManager
    systemctl enable greetd
    systemctl enable docker
"

gui_step greetd 80 "Configuring login manager..."

# Configure greetd — auto-login to Hyprland
# Write directly to avoid shell quoting issues
mkdir -p /mnt/etc/greetd
cat > /mnt/etc/greetd/config.toml << EOF
[terminal]
vt = 1

[default_session]
command = "Hyprland"
user = "$USERNAME"
EOF

# ─── Set password (non-interactive — already collected) ──────
# Use printf pipe to avoid shell interpolation issues with special chars in passwords
printf '%s:%s\n' "$USERNAME" "$PASSWORD1" | arch-chroot /mnt chpasswd
info "Password set"

# ─── Copy Costa OS files ─────────────────────────────────────
gui_step costafiles 82 "Installing Costa OS files..."
info "Installing Costa OS..."

COSTA_SHARE="/mnt/usr/share/costa-os"
USER_HOME="/mnt/home/$USERNAME"

# Copy AI router
mkdir -p "$COSTA_SHARE/ai-router"
cp -r /usr/share/costa-os/ai-router/* "$COSTA_SHARE/ai-router/" 2>/dev/null || true
chmod +x "$COSTA_SHARE/ai-router/costa-"* 2>/dev/null || true

# Copy installer
mkdir -p "$COSTA_SHARE/installer"
cp -r /usr/share/costa-os/installer/* "$COSTA_SHARE/installer/" 2>/dev/null || true

# Symlink CLI tools
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-ai /usr/local/bin/costa-ai
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-keybinds /usr/local/bin/costa-keybinds
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-ai-project-select /usr/local/bin/costa-ai-project-select
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-ai-file-search /usr/local/bin/costa-ai-file-search
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-ai-screenshot /usr/local/bin/costa-ai-screenshot
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-keybinds-gui /usr/local/bin/costa-keybinds-gui
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-nav /usr/local/bin/costa-nav
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-agents /usr/local/bin/costa-agents
arch-chroot /mnt ln -sf /usr/share/costa-os/ai-router/costa-flow /usr/local/bin/costa-flow
arch-chroot /mnt ln -sf /usr/share/costa-os/installer/costa-settings /usr/local/bin/costa-settings

# Copy default configs to user skeleton
SKEL="$USER_HOME"
mkdir -p "$SKEL/.config/hypr" "$SKEL/.config/waybar/scripts" "$SKEL/.config/waybar/templates" \
         "$SKEL/.config/ghostty" "$SKEL/.config/rofi" "$SKEL/.config/dunst" \
         "$SKEL/.config/costa/knowledge" "$SKEL/.config/costa/scripts" \
         "$SKEL/.local/bin" "$SKEL/.local/share/applications" \
         "$SKEL/Pictures/Screenshots"

cp /usr/share/costa-os/configs/hypr/hyprland.conf "$SKEL/.config/hypr/" 2>/dev/null || true
cp /usr/share/costa-os/configs/dunst/dunstrc "$SKEL/.config/dunst/" 2>/dev/null || true
cp /usr/share/costa-os/configs/ghostty/config "$SKEL/.config/ghostty/" 2>/dev/null || true
cp /usr/share/costa-os/configs/rofi/config.rasi "$SKEL/.config/rofi/" 2>/dev/null || true

# Waybar — copy style, templates, and generate a working config
cp /usr/share/costa-os/configs/waybar/style.css "$SKEL/.config/waybar/" 2>/dev/null || true
cp /usr/share/costa-os/configs/waybar/templates/*.jsonc "$SKEL/.config/waybar/templates/" 2>/dev/null || true

# Copy waybar scripts
if [ -d /usr/share/costa-os/configs/waybar/scripts ]; then
    cp /usr/share/costa-os/configs/waybar/scripts/*.sh "$SKEL/.config/waybar/scripts/" 2>/dev/null || true
    # Voice status scripts go in waybar root (referenced without scripts/ prefix)
    for f in voice-claude-status.sh voice-claude-viewer.sh ptt-status.sh; do
        [ -f "$SKEL/.config/waybar/scripts/$f" ] && cp "$SKEL/.config/waybar/scripts/$f" "$SKEL/.config/waybar/"
    done
    chmod +x "$SKEL/.config/waybar/scripts/"*.sh "$SKEL/.config/waybar/"*.sh 2>/dev/null || true
fi

# Generate a working single-bar config from template (first-boot will regenerate per-monitor)
if [ -f /usr/share/costa-os/configs/waybar/templates/main-bar.jsonc ]; then
    sed -e 's/"output": "__OUTPUT__",//' \
        -e 's/"persistent-workspaces": "__PERSISTENT_WORKSPACES__"/"persistent-workspaces": {"1":[],"2":[],"3":[],"4":[]}/' \
        -e 's/"timezone": "__TIMEZONE__",/"timezone": "",/' \
        /usr/share/costa-os/configs/waybar/templates/main-bar.jsonc \
        > "$SKEL/.config/waybar/config"
fi

# Copy knowledge base
cp /usr/share/costa-os/knowledge/*.md "$SKEL/.config/costa/knowledge/" 2>/dev/null || true

# Copy agent definitions
mkdir -p "$SKEL/.config/costa/agents"
cp /usr/share/costa-os/configs/costa/agents/*.yaml "$SKEL/.config/costa/agents/" 2>/dev/null || true

# Waybar generator script
cp /usr/share/costa-os/scripts/generate-waybar-config.sh "$SKEL/.config/costa/scripts/" 2>/dev/null || true
chmod +x "$SKEL/.config/costa/scripts/generate-waybar-config.sh" 2>/dev/null || true

# Copy all shipped wallpapers
mkdir -p "$SKEL/Pictures/Wallpapers"
cp /usr/share/costa-os/wallpapers/* "$SKEL/Pictures/Wallpapers/" 2>/dev/null || true

# Copy music widget
if [ -d /usr/share/costa-os/music-widget ]; then
    mkdir -p "$SKEL/.config/costa/music-widget"
    cp /usr/share/costa-os/music-widget/*.py "$SKEL/.config/costa/music-widget/" 2>/dev/null || true
fi

# Copy settings app + launcher
cp /usr/share/costa-os/installer/settings.py "$COSTA_SHARE/installer/" 2>/dev/null || true
cp /usr/share/costa-os/installer/costa-settings "$COSTA_SHARE/installer/" 2>/dev/null || true
chmod +x "$COSTA_SHARE/installer/costa-settings" 2>/dev/null || true

# Desktop entries for rofi/app launcher
if [ -d /usr/share/costa-os/configs/applications ]; then
    mkdir -p "$SKEL/.local/share/applications"
    cp /usr/share/costa-os/configs/applications/*.desktop "$SKEL/.local/share/applications/" 2>/dev/null || true
fi

# Ensure ~/.local/bin is on PATH
if ! grep -q 'local/bin' "$SKEL/.zshrc" 2>/dev/null; then
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$SKEL/.zshrc"
fi

# Copy scripts (wallpaper, ollama-manager, claude setup, etc.)
mkdir -p "$SKEL/.config/costa/scripts"
mkdir -p "$COSTA_SHARE/scripts"
cp /usr/share/costa-os/scripts/*.sh "$COSTA_SHARE/scripts/" 2>/dev/null || true
cp /usr/share/costa-os/scripts/*.py "$COSTA_SHARE/scripts/" 2>/dev/null || true
chmod +x "$COSTA_SHARE/scripts/"*.sh "$COSTA_SHARE/scripts/"*.py 2>/dev/null || true
cp /usr/share/costa-os/scripts/wallpaper.sh "$SKEL/.config/costa/scripts/" 2>/dev/null || true
cp /usr/share/costa-os/scripts/ollama-manager.sh "$SKEL/.config/costa/scripts/" 2>/dev/null || true
cp /usr/share/costa-os/scripts/headless-preview.py "$SKEL/.config/costa/scripts/" 2>/dev/null || true
chmod +x "$SKEL/.config/costa/scripts/"*.sh "$SKEL/.config/costa/scripts/"*.py 2>/dev/null || true

# Copy voice assistant (optional — only if user has voice tier)
if [ -d /usr/share/costa-os/voice-assistant ]; then
    mkdir -p "$SKEL/.config/costa/voice" "$SKEL/.config/costa/vad"
    cp /usr/share/costa-os/voice-assistant/push-to-talk.sh "$SKEL/.config/costa/voice/" 2>/dev/null || true
    cp /usr/share/costa-os/voice-assistant/vad_daemon.py "$SKEL/.config/costa/vad/" 2>/dev/null || true
    cp /usr/share/costa-os/voice-assistant/vad_record.py "$SKEL/.config/costa/vad/" 2>/dev/null || true
    chmod +x "$SKEL/.config/costa/voice/"*.sh 2>/dev/null || true
fi

# Copy Claude Code knowledge file
cp /usr/share/costa-os/configs/claude/CLAUDE.md "$SKEL/.config/costa/CLAUDE.md.template" 2>/dev/null || true

# Copy first-boot script
cp /usr/share/costa-os/installer/first-boot.sh "$SKEL/.config/hypr/first-boot.sh"
chmod +x "$SKEL/.config/hypr/first-boot.sh"

# Add first-boot trigger to hyprland.conf
echo "" >> "$SKEL/.config/hypr/hyprland.conf"
echo "# First-boot setup (removes itself after running)" >> "$SKEL/.config/hypr/hyprland.conf"
echo 'exec-once = bash -c "if [ ! -f ~/.config/costa/config.json ]; then ghostty -e ~/.config/hypr/first-boot.sh; fi"' >> "$SKEL/.config/hypr/hyprland.conf"

# Fix ownership
arch-chroot /mnt chown -R "$USERNAME:$USERNAME" "/home/$USERNAME"

# ─── Install yay (AUR helper) ────────────────────────────────
gui_step yay 92 "Installing yay (AUR helper)..."
info "Installing yay (AUR helper)..."
arch-chroot /mnt su - "$USERNAME" -c '
    cd /tmp
    git clone https://aur.archlinux.org/yay-bin.git
    cd yay-bin
    makepkg -si --noconfirm
    cd /tmp && rm -rf yay-bin
' || warn "yay installation failed — AUR packages will need manual setup"

# ─── Done ─────────────────────────────────────────────────────
gui_step done 100 "Installation complete!"

if [ "$GUI_MODE" = true ]; then
    echo "DONE:"
    # Clean up config file (contains password)
    rm -f "$GUI_CONFIG"
else
    echo ""
    echo -e "${GREEN}"
    echo '   ╔═══════════════════════════════════════╗'
    echo '   ║     Costa OS installed successfully!  ║'
    echo '   ║                                       ║'
    echo '   ║     Remove the USB and reboot.        ║'
    echo '   ╚═══════════════════════════════════════╝'
    echo -e "${RESET}"
    echo ""
    prompt "Reboot now? (y/n):"
    if [ "$REPLY" = "y" ]; then
        umount -R /mnt
        reboot || reboot -f
    fi
fi
