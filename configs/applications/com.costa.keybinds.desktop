[Desktop Entry]
Name=Keybind Configurator
GenericName=Keyboard & Mouse Settings
Comment=Configure Hyprland keyboard shortcuts and mouse button bindings
Exec=costa-keybinds-gui
Icon=preferences-desktop-keyboard-shortcuts
Terminal=false
Type=Application
Categories=Settings;System;
Keywords=keybind;shortcut;hotkey;keyboard;mouse;binding;
StartupWMClass=com.costa.keybinds
