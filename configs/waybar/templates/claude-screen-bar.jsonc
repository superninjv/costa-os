// Costa OS — Claude Screen Bar
// Headless virtual monitor for AI navigation.
// Placeholders: __OUTPUT__, __PERSISTENT_WORKSPACES__, __TIMEZONE__
{
  "name": "claude-screen-bar",
  "output": "__OUTPUT__",
  "layer": "top",
  "gtk-layer-shell": false,
  "position": "top",
  "height": 24,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/claude-screen-status"],
  "modules-right": ["clock"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true,
    "all-outputs": false,
    "persistent-workspaces": "__PERSISTENT_WORKSPACES__"
  },

  "custom/claude-screen-status": {
    "format": "\udb81\udea9 Claude Screen",
    "interval": 86400,
    "exec": "echo tooltip",
    "tooltip-format": "Headless virtual monitor for AI navigation"
  },

  "clock": {
    "format": "{:%I:%M}",
    "timezone": "__TIMEZONE__"
  }
}
