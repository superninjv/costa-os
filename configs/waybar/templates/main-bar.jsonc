// Costa OS — Main Bar
// Placeholders: __OUTPUT__, __PERSISTENT_WORKSPACES__, __TIMEZONE__
{
  "name": "main-bar",
  "output": "__OUTPUT__",
  "layer": "top",
  "gtk-layer-shell": false,
  "position": "top",
  "height": 28,
  "spacing": 0,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "tooltip": true,

  "modules-left": [
    "custom/costa-ai"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "custom/ptt",
    "pulseaudio",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "\uf120",
      "2": "\uf0ac",
      "3": "\uf121",
      "4": "\uf013",
      "5": "\uf11b",
      "6": "\uf025",
      "default": "\uf444"
    },
    "on-click": "activate",
    "sort-by-number": true,
    "all-outputs": false,
    "show-special": false,
    "persistent-workspaces": "__PERSISTENT_WORKSPACES__"
  },

  "custom/costa-ai": {
    "format": "{}",
    "return-type": "json",
    "max-length": 50,
    "exec": "~/.config/waybar/scripts/costa-ai-status.sh",
    "on-click": "~/.config/waybar/scripts/toggle-app.sh costa-ai-widget '/usr/bin/python3 $HOME/.config/costa-ai-widget/widget.py'",
    "on-click-right": "~/.config/waybar/scripts/voice-click.sh",
    "tooltip": true
  },

  "custom/troubleshoot": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/troubleshoot-indicator.sh",
    "interval": 60,
    "tooltip": true,
    "on-click": "ghostty -e bash -c '~/.config/waybar/scripts/troubleshoot.sh; echo; read -p \"Press Enter...\"'"
  },

  "custom/headless-preview": {
    "format": "{}",
    "return-type": "json",
    "exec": "if hyprctl monitors -j 2>/dev/null | grep -q HEADLESS; then echo '{\"text\": \"\\uf108\", \"tooltip\": \"Claude Screen\"}'; else echo '{\"text\": \"\"}'; fi",
    "on-click": "/usr/bin/python3 /usr/share/costa-os/scripts/headless-preview.py",
    "interval": 30
  },

  "custom/ptt": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/ptt-status.sh",
    "on-click": "~/.config/hypr/push-to-talk.sh",
    "tooltip": true
  },

  "custom/now-playing": {
    "format": "{}",
    "return-type": "json",
    "max-length": 35,
    "exec": "~/.config/waybar/scripts/now-playing.sh",
    "interval": 3,
    "tooltip": true,
    "on-click": "/usr/bin/python3 $HOME/.config/music-widget/widget.py",
    "on-click-middle": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl position 5+",
    "on-scroll-down": "playerctl position 5-"
  },

  "custom/git": {
    "format": "{}",
    "return-type": "json",
    "max-length": 10,
    "exec": "~/.config/waybar/scripts/git-status.sh",
    "interval": 10,
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/toggle-app.sh lazygit lazygit"
  },

  "custom/claude": {
    "format": "\udb81\udea9",
    "interval": 86400,
    "exec": "echo tooltip",
    "tooltip-format": "Claude Code",
    "on-click": "~/.config/waybar/scripts/claude-launcher.sh launch",
    "on-click-right": "~/.config/waybar/scripts/claude-launcher.sh menu"
  },

  "clock": {
    "timezone": "__TIMEZONE__",
    "format": "{:%I:%M}",
    "format-alt": "{:%a %b %d}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "interval": 60
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "\udb81\udd9f",
    "format-icons": {
      "default": ["\uf026", "\uf027", "\uf028"]
    },
    "tooltip-format": "{desc} — {volume}%",
    "on-click": "pavucontrol",
    "on-click-middle": "swayosd-client --output-volume mute-toggle",
    "on-scroll-up": "swayosd-client --output-volume 5",
    "on-scroll-down": "swayosd-client --output-volume -5",
    "scroll-step": 5
  },

  "tray": {
    "icon-size": 16,
    "spacing": 6,
    "show-passive-items": true
  },

  "battery": {
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon}",
    "format-charging": "\udb80\udc84",
    "format-plugged": "\udb80\udc84",
    "format-icons": ["\udb80\udc7a", "\udb80\udc7b", "\udb80\udc7c", "\udb80\udc7d", "\udb80\udc79"],
    "tooltip-format": "{capacity}% — {timeTo}"
  },

  "custom/gpu": {
    "format": "\udb80\udea8 {}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/gpu-vram.sh",
    "interval": 5,
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/toggle-app.sh amdgpu_top amdgpu_top"
  },

  "cpu": {
    "format": "\uf2db {usage}%",
    "interval": 5,
    "tooltip-format": "CPU: {usage}% — {avg_frequency} GHz",
    "on-click": "~/.config/waybar/scripts/toggle-app.sh btm btm"
  },

  "memory": {
    "format": "\uf538 {used:0.1f}G",
    "interval": 5,
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)",
    "on-click": "~/.config/waybar/scripts/toggle-app.sh btm btm"
  },

  "custom/power": {
    "format": "\u23fb",
    "interval": 86400,
    "exec": "echo tooltip",
    "tooltip-format": "Power",
    "on-click": "~/.config/rofi/powermenu.sh"
  }
}
